PROVIDER_MODE=live
MARKET_MODE=crypto

# Alpaca credentials. Required for real crypto scans.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets

# Crypto scan universe. CRYPTO_SYMBOLS is the safe fallback list, not the full dynamic universe.
CRYPTO_LOCATION=us
CRYPTO_UNIVERSE_MODE=dynamic_safe_fallback
CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,LINK/USD,UNI/USD,AAVE/USD,DOGE/USD,LTC/USD,BCH/USD
CRYPTO_SCAN_MINUTES=90
CRYPTO_MIN_QUOTE_VOLUME=50000
CRYPTO_MAX_SPREAD_PCT=0.35
CRYPTO_MIN_ORDERBOOK_NOTIONAL_DEPTH=25000
CRYPTO_DEPTH_BPS=25

# Kraken execution-venue quote/depth gate. Public data only; no Kraken key required.
VENUE_PROVIDER=kraken
KRAKEN_BASE_URL=https://api.kraken.com
KRAKEN_MAX_SPREAD_PCT=0.35
KRAKEN_MAX_QUOTE_AGE_SECONDS=30
KRAKEN_MIN_ORDERBOOK_NOTIONAL_DEPTH=25000
MAX_ALPACA_VENUE_DEVIATION_PCT=0.50

# Durable SQLite-compatible storage for Streamlit Cloud.
# Leave blank for local SQLite development.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Strategy thresholds.
MIN_SCORE=7.5
SHORTLIST_SIZE=25
MAX_STOP_DISTANCE_PCT=3.0
MIN_RISK_REWARD=2.0
MAX_VWAP_EXTENSION_PCT=8.0
SCAN_REFRESH_SECONDS=180
MOCK_STARTING_CASH=10000

# Crypto-first score weights.
WEIGHT_RVOL=0.35
WEIGHT_ACCELERATION=0.30
WEIGHT_BREAKOUT=0.25
WEIGHT_CATALYST=0.0
WEIGHT_REVERSAL_RISK=-0.10
