PROVIDER_MODE=live

# Alpaca Free/IEX data. Required for real scans.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_FEED=iex

# Durable SQLite-compatible storage for Streamlit Cloud.
# Leave blank for local SQLite development.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Strategy thresholds.
MIN_SCORE=7.5
ALERT_SCORE=8.0
SHORTLIST_SIZE=25
MAX_STOP_DISTANCE_PCT=3.0
MIN_RISK_REWARD=2.0
MAX_VWAP_EXTENSION_PCT=8.0
SCAN_REFRESH_SECONDS=180
MOCK_STARTING_CASH=10000

# Score weights.
WEIGHT_RVOL=0.30
WEIGHT_ACCELERATION=0.25
WEIGHT_BREAKOUT=0.20
WEIGHT_CATALYST=0.15
WEIGHT_REVERSAL_RISK=-0.10
